# App
NEXT_PUBLIC_APP_NAME="Propósito em Ação"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BETA_FEEDBACK_URL=""

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""
SUPABASE_PROJECT_ID=""

# Supabase operator/preview CLI variables. Do not set these as browser variables.
SUPABASE_ACCESS_TOKEN=""
SUPABASE_PREVIEW_DB_URL=""
SUPABASE_PREVIEW_CONFIRM=""
SUPABASE_PREVIEW_PROJECT_REF=""
SUPABASE_TYPES_OUTPUT="src/types/database.ts"
SUPABASE_PREVIEW_STORAGE_BUCKET=""
SUPABASE_PREVIEW_TEST_EMAIL_DOMAIN=""
SUPABASE_PREVIEW_KEEP_FIXTURES=""
SUPABASE_SKIP_STORAGE_RLS=""

# Runtime
APP_RUNTIME_MODE="local-demo"
AI_REAL_ENABLED="false"
EMAIL_REAL_ENABLED="false"
EMAIL_DOMAIN_VERIFIED="false"
ANALYTICS_REAL_ENABLED="false"
FEEDBACK_REAL_ENABLED="false"

# AI providers
AI_PROVIDER_DEFAULT="automatic"
AI_REQUEST_TIMEOUT_MS="20000"
AI_DAILY_USER_LIMIT="50"
AI_AUDIT_RETENTION_DAYS="90"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL=""
# OpenAI model defaults have been removed in favor of DeepSeek V4 Pro as the default.
OPENAI_MODEL_FAST=""
OPENAI_MODEL_PRO=""
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
# The default model is Nvidia's DeepSeek V4 Pro (deepseek-ai/deepseek-v4-pro)
DEEPSEEK_MODEL_FLASH="deepseek-ai/deepseek-v4-pro"
DEEPSEEK_MODEL_PRO="deepseek-ai/deepseek-v4-pro"

# Email
EMAIL_PROVIDER="resend"
EMAIL_FROM=""
EMAIL_FROM_AUTH="acesso@notify.example.com"
EMAIL_FROM_NOTIFICATIONS="notificacoes@notify.example.com"
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
RESEND_TEST_RECIPIENT=""

# Node environment
NODE_ENV="development"
NIXPACKS_NODE_VERSION="22"

# External QA targets
PLAYWRIGHT_BASE_URL=""
PREVIEW_URL=""

# Notes
# Do not put real secrets in this file.
# NEXT_PUBLIC_* values are sent to the browser.
# APP_RUNTIME_MODE and *_REAL_ENABLED are server-side runtime controls.
# SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET, OPENAI_API_KEY, provider keys and webhook secrets are server-only.
# SUPABASE_ACCESS_TOKEN and SUPABASE_PREVIEW_DB_URL are operator-only, never app runtime.
