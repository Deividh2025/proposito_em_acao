# App
NEXT_PUBLIC_APP_NAME="Propósito em Ação"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BETA_FEEDBACK_URL=""

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_PROJECT_ID=""

# Runtime
APP_RUNTIME_MODE="local-demo"
AI_REAL_ENABLED="false"
EMAIL_REAL_ENABLED="false"
ANALYTICS_REAL_ENABLED="false"
FEEDBACK_REAL_ENABLED="false"

# AI providers
OPENAI_API_KEY=""
OPENAI_MODEL=""
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL_FLASH="deepseek-v4-flash"
DEEPSEEK_MODEL_PRO="deepseek-v4-pro"

# Email
EMAIL_PROVIDER=""
EMAIL_FROM=""

# Node environment
NODE_ENV="development"

# Notes
# Do not put real secrets in this file.
# NEXT_PUBLIC_* values are sent to the browser.
# APP_RUNTIME_MODE and *_REAL_ENABLED are server-side runtime controls.
# SUPABASE_SERVICE_ROLE_KEY, OPENAI_API_KEY and provider keys are server-only.
